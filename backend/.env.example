# ============================================================
# MetaBody Club — Variáveis de Ambiente (Backend)
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no Git
# ============================================================

# ── Servidor ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── CORS (domínio do frontend) ───────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_aqui
JWT_REFRESH_SECRET=outro_segredo_diferente_e_longo_aqui

# ── AWS RDS PostgreSQL ───────────────────────────────────────
DB_HOST=seu-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=metabody
DB_USER=metabody_user
DB_PASSWORD=senha_segura_do_banco
# Conteúdo PEM do certificado RDS (obrigatório em produção)
# Cole o conteúdo do arquivo rds-ca-cert.pem substituindo quebras de linha por \n
RDS_CA_CERT=

# ── AWS S3 + CloudFront ──────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=metabody-media
CLOUDFRONT_URL=https://dXXXXXXXXXXXX.cloudfront.net

# ── Email (AWS SES — para recuperar senha) ───────────────────
# SES_FROM=noreply@metabody.com.br
