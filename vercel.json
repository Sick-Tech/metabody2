{
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/admin-login/?$",
      "dest": "/admin-login.html"
    },
    {
      "src": "/admin/?$",
      "dest": "/admin.html"
    },
    {
      "src": "/dashboard/?$",
      "dest": "/dashboard.html"
    },
    {
      "src": "/login/?$",
      "dest": "/login.html"
    },
    {
      "src": "/trilha/?$",
      "dest": "/trilha.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(?!.*\\.(?:js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$)(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/.*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
